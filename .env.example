# Feishu bot — Claude
# 把这份文件复制成 .env 并填好。.env 已在 .gitignore 中。
# 仅需要接入飞书时才填，本地 cc-webui 单机使用无需任何配置。

# ─────────────────────────────────────────────────────────────────────
# 传输模式
# ─────────────────────────────────────────────────────────────────────
# 默认走 WebSocket 长连接（cc-webui 主动连飞书，不需要公网入口）
# 设置 FEISHU_USE_WEBHOOK=1 切换到 HTTP webhook 模式（需要公网 HTTPS URL）
# FEISHU_USE_WEBHOOK=1

# ─────────────────────────────────────────────────────────────────────
# Claude bot 凭据
# ─────────────────────────────────────────────────────────────────────
# WS 模式：只需要 APP_ID + APP_SECRET
# Webhook 模式：还需要 ENCRYPT_KEY + VERIFY_TOKEN（开发者后台「事件与回调 → 加密策略」）
FEISHU_CLAUDE_APP_ID=
FEISHU_CLAUDE_APP_SECRET=
FEISHU_CLAUDE_ENCRYPT_KEY=
FEISHU_CLAUDE_VERIFY_TOKEN=

# Codex bot (optional, leave blank for MVP)
# FEISHU_CODEX_APP_ID=
# FEISHU_CODEX_APP_SECRET=
# FEISHU_CODEX_ENCRYPT_KEY=
# FEISHU_CODEX_VERIFY_TOKEN=

# 飞书群 @ 机器人时如果还没绑定 cc-webui group，会自动建一个新 group。
# 自动建的 group 默认 cwd（按优先级 fallback：本变量 > CC_WEBUI_CWD > server 启动目录）。
# 后续可以在飞书群里用 /cd <path> 切到别的目录。
# FEISHU_DEFAULT_CWD=/Users/xuqiang/code/cc-webui

# Override the OpenAPI base for Lark international (default: https://open.feishu.cn)
# FEISHU_BASE_URL=https://open.larksuite.com

# Override dotenv path if .env lives elsewhere
# CC_WEBUI_DOTENV=/abs/path/to/.env
